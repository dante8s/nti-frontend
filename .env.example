# Local dev: omit VITE_API_BASE_URL — axios uses the Vite dev server and proxy /api → http://localhost:8080
# (see vite.config.js). Restart `npm run dev` after changes.

# Direct API URL (bypass proxy). Must match Spring server.port and app.frontend-url CORS:
# VITE_API_BASE_URL=http://localhost:8080
